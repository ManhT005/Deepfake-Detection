='same',\n        kernel_initializer='he_normal',   # paper dГ№ng He normal init\n        kernel_regularizer=tf.keras.regularizers.l2(1e-4)  # L2 reg\n    )(x)\n    x = layers.BatchNormalization()(x)    # б»•n Д‘б»Ӣnh training\n    x = layers.Activation('relu')(x)\n    x = layers.MaxPooling2D(pool_size=(2, 2))(x)  # giбәЈm spatial dim\n    x = layers.Dropout(dropout_rate)(x)\n    return x\n\n# Build full CNN backbone\ninputs = layers.Input(shape=(224, 224, 3))\n\nx = build_cnn_block(inputs, filters=32)   # 224вҶ’112\nx = build_cnn_block(x, filters=64)        # 112вҶ’56\nx = build_cnn_block(x, filters=128)       # 56вҶ’28\nx = build_cnn_block(x, filters=256)       # 28вҶ’14\n\nprint(\"Shape sau 4 conv blocks:\", x.shape)\n# Kбәҝt quбәЈ mong Д‘б»Јi: (None, 14, 14, 256)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-25T10:16:02.473116Z","iopub.execute_input":"2026-05-25T10:16:02.473938Z","iopub.status.idle":"2026-05-25T10:16:02.551637Z","shell.execute_reply.started":"2026-05-25T10:16:02.473908Z","shell.execute_reply":"2026-05-25T10:16:02.550737Z"}},"outputs":[{"name":"stdout","text":"Shape sau 4 conv blocks: (None, 14, 14, 256)\n","output_type":"stream"}],"execution_count":8},{"cell_type":"code","source":"def build_mhsa_block(x):\n    \"\"\"\n    Sau conv blocks: Reshape вҶ’ Dropout вҶ’ MHSA вҶ’ Residual вҶ’ LayerNorm\n    ДҗГўy lГ  phбә§n paper gб»Қi lГ  'sequential integration'\n    \"\"\"\n    # BЖ°б»ӣc 1: Reshape tб»« (14, 14, 256) вҶ’ (196, 256)\n    # MHSA cбә§n input dбәЎng sequence, khГҙng phбәЈi spatial grid\n    seq_len = x.shape[1] * x.shape[2]   # 14Г—14 = 196\n    x_reshaped = layers.Reshape((seq_len, 256))(x)  # (None, 196, 256)\n\n    # BЖ°б»ӣc 2: Dropout trЖ°б»ӣc attention (paper dГ№ng 0.3)\n    x_drop = layers.Dropout(0.3)(x_reshaped)\n\n    # BЖ°б»ӣc 3: Multi-Head Self-Attention\n    # num_heads=4, key_dim=64 вҖ” Д‘Гәng theo paper Table 2\n    attn_output = layers.MultiHeadAttention(\n        num_heads=4,\n        key_dim=64,\n        dropout=0.2          # dropout bГӘn trong attention (paper: 0.2)\n    )(x_drop, x_drop)        # self-attention: query=key=value=x_drop\n\n    # BЖ°б»ӣc 4: Residual connection вҖ” cб»ҷng input gб»‘c vГ o output attention\n    # GiГәp giб»Ҝ lбәЎi thГҙng tin low-level tб»« CNN, trГЎnh mбәҘt mГЎt\n    x_residual = layers.Add()([x_reshaped, attn_output])\n\n    # BЖ°б»ӣc 5: Layer Normalization\n    x_norm = layers.LayerNormalization()(x_residual)\n\n    return x_norm\n\n# GбәҜn MHSA vГ o sau CNN backbone\nx = build_mhsa_block(x)\n\n# Global Average Pooling: (196, 256) вҶ’ (256,)\n# Gб»ҷp toГ n bб»ҷ sequence thГ nh 1 vector Д‘бә·c trЖ°ng\nx = layers.GlobalAveragePooling1D()(x)\n\n# Dense layers вҖ” phГўn loбәЎi cuб»‘i\nx = layers.Dense(128)(x)\nx = layers.BatchNormalization()(x)\nx = layers.Dropout(0.3)(x)\n\nx = layers.Dense(64)(x)\nx = layers.BatchNormalization()(x)\nx = layers.Dropout(0.3)(x)\n\n# Output layer: sigmoid vГ¬ binary classification\noutputs = layers.Dense(1, activation='sigmoid')(x)\n\n# TбәЎo model\nmodel = Model(inputs=inputs, outputs=outputs)\nmodel.summary()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-25T10:16:05.259034Z","iopub.execute_input":"2026-05-25T10:16:05.259962Z","iopub.status.idle":"2026-05-25T10:16:05.375032Z","shell.execute_reply.started":"2026-05-25T10:16:05.259931Z","shell.execute_reply":"2026-05-25T10:16:05.374465Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"\u001b[1mModel: \"functional_1\"\u001b[0m\n","text/html":"<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\">Model: \"functional_1\"</span>\n</pre>\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"в”Ҹв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”ів”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”ів”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”ів”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ